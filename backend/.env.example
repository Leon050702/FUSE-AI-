# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# REQUIRED — your own DeepSeek API key from platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# REQUIRED for login — any long random string (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional
PORT=3001
DEEPSEEK_MODEL=deepseek-chat
ALLOWED_ORIGIN=*

# Optional — FUSE staging integration (leave blank if not connecting)
FUSE_BASE_URL=https://fuse-stg.johor.gov.my
FUSE_TOKEN_PATH=/api/v1/smartfuse-api/token
FUSE_SUBMIT_PATH=/api/v1/smartfuse-api/data
FUSE_SYSTEM_KEY=
FUSE_SYSTEM_SECRET=
FUSE_USER_ID=
